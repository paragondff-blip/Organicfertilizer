# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# STRIPE_SECRET_KEY: For processing payments securely.
STRIPE_SECRET_KEY="sk_test_..."

# FIREBASE_SERVICE_ACCOUNT: Required for backend administrative operations.
# Paste the JSON service account content as a string or handle via secret manager.
FIREBASE_SERVICE_ACCOUNT='{}'
