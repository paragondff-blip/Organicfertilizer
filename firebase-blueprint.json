{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Biscuit product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "brand": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "ingredients": { "type": "string" },
        "nutritionInfo": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "integer" },
        "isNew": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "discountPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "categoryId"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "paymentStatus"]
    },
    "Review": {
      "title": "Review",
      "description": "Product reviews",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupons",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minOrder": { "type": "number" },
        "active": { "type": "boolean" },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountType", "value"]
    },
    "Blog": {
      "title": "Blog",
      "description": "Blog posts",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string" },
        "tags": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Hero banners",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["image", "active"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Product brands",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name", "logo"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name", "slug"]
    },
    "Settings": {
      "title": "Settings",
      "description": "App settings and page content",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "content": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["key"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "email", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available biscuits"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Biscuit categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Active coupons"
    },
    "/blogs/{blogId}": {
      "schema": "Blog",
      "description": "Informational blog posts"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Promotional banners"
    },
    "/brands/{brandId}": {
      "schema": "Brand",
      "description": "Product brands"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global application settings"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Customer messages"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    }
  }
}
